<odoo>
    <!-- Check subscripion every day      -->
    <record id="Check_subscription_expiration_of_whatsapp_module" model="ir.cron">
        <field name="name">Check subscription expiration on monthly basis.</field>
        <field name="model_id" ref="model_whatsapp_payment_wizard"/>
        <field name="state">code</field>
        <field name="code">model.check_whatsapp_subscriptions()</field>
        <field name="user_id" ref="base.user_root"/>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active" eval="True"/>
        
    </record> 

</odoo>
