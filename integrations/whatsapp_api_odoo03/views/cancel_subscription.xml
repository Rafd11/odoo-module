<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Wizard Form -->
    <record id="view_cancel_subscription_wizard" model="ir.ui.view">
        <field name="name">cancel.subscription.wizard.form</field>
        <field name="model">cancel.subscription.wizard</field>
        <field name="arch" type="xml">
            <form string="Cancel Subscription">
                <div class="o_form_label" style="font-size:18px;font-weight:600;color:#d9534f;">
                    Are you sure you want to cancel your WhatsApp subscription?
                </div>
                <p style="color:#666;">Once canceled, your service will stop immediately.</p>
                
                <footer>
                    <button string="Yes, Cancel Now"
                            name="action_confirm_cancel"
                            type="object"
                            class="btn btn-danger"/>

                    <button string="No"
                            special="cancel"
                            class="btn btn-secondary"/>
                </footer>
            </form>

        </field>
    </record>

    <!-- Action for Popup -->
    <record id="action_cancel_subscription_popup" model="ir.actions.act_window">
        <field name="name">Cancel Whatsapp Subscription </field>
        <field name="res_model">cancel.subscription.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_cancel_subscription_wizard"/>
        <field name="target">new</field>
    </record>

</odoo>
