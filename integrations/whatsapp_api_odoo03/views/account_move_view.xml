<odoo>
    <record id="view_move_form_inherit_custom_column" model="ir.ui.view">
      <field name="name">account.move.form.inherit.custom.code</field>
      <field name="model">account.move</field>
      <field name="inherit_id" ref="account.view_move_form" />
      <field name="arch" type="xml">
        <xpath expr="//field[@name='invoice_line_ids']/list/field[@name='product_id']" position="before">
          <field name="combo_product_name" readonly="1"/>
        </xpath>
      </field>
    </record>
  </odoo>