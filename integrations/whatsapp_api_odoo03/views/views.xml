<odoo>
  <data>
    <!-- explicit list view definition -->

    <record model="ir.ui.view" id="sale_order_whatsapp_inherit">
      <field name="name">sale.order.whatsapp.inherit</field>
      <field name="model">sale.order</field>
      <field name="inherit_id" ref="sale.view_order_form"/>
      <field name="arch" type="xml">
        <button name="action_quotation_send" position="after">
          <button name="send_pdf_for_whatsapp_on_web_side_sale" id="send_by_whatsapp" string="Send on Whatsapp" type="object" class="oe_highlight"  icon="fa-whatsapp"/>
        </button>

        
      </field>
    </record>

    <record model="ir.ui.view" id="invoice_whatsapp_inherit">
      <field name="name">account.move.whatsapp.inherit</field>
      <field name="model">account.move</field>
      <field name="inherit_id" ref="account.view_move_form"/>
      <field name="arch" type="xml">
          <xpath expr="//header" position="inside">
            <button name="send_pdf_for_whatsapp_on_web_side_account_move"  string="Send on Whatsapp" type="object" class="oe_highlight"  icon="fa-whatsapp"/>
          </xpath>

          <xpath expr="//field[@name='invoice_date']" position="after">
            <field name="followup_date" />
          </xpath>
      </field>
    </record>

    <record model="ir.ui.view" id="purchase_whatsapp_inherit">
      <field name="name">purchase.order.whatsapp.inherit</field>
      <field name="model">purchase.order</field>
      <field name="inherit_id" ref="purchase.purchase_order_form"/>
      <field name="arch" type="xml">
          <xpath expr="//header" position="inside">
            <button name="send_pdf_for_whatsapp_on_web_side"  string="Send on Whatsapp" type="object" class="oe_highlight"  icon="fa-whatsapp"/>
          </xpath>
      </field>
    </record>

    <record model="ir.ui.view" id="res_partner_inherit_form_view">
      <field name="name">res.patner.inherit</field>
      <field name="model">res.partner</field>
      <field name="inherit_id" ref="base.view_partner_form"/>
      <field name="arch" type="xml">
          <xpath expr="//field[@name='parent_id']" position="after">
            <field name="country_id" />
            <field name="mobile" />
          </xpath>
      </field>
    </record>

    <record id="view_picking_form_inherit_whatsapp" model="ir.ui.view">
        <field name="name">stock.picking.form.inherit.whatsapp</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">

            <!-- Add button in header -->
            <xpath expr="//header" position="inside">
                <button name="action_send_whatsapp"
                        string="Send on WhatsApp"
                        type="object"
                        class="btn-primary"
                        icon="fa-whatsapp"/>
            </xpath>

        </field>
    </record>


    <record id="product_templateitems__inherit" model="ir.ui.view">
      <field name="name">product.template.form.inherit</field>
      <field name="model">product.template</field>
      <field name="inherit_id" ref="product.product_template_only_form_view"/>
      <field name="arch" type="xml">
          <xpath expr="//group" position="inside">
              <group>
                  <field name="Product_sku_id"/>
                  <field name="arabic_name"/>
              </group>
          </xpath>
      </field>
  </record>

  </data>
</odoo>
