<odoo>
    <!-- list (List) View -->
    <record id="wallet_recharge_list_list" model="ir.ui.view">
    <field name="name">whatsapp.payment.wizard.list</field>
    <field name="model">whatsapp.payment.wizard</field>
    <field name="arch" type="xml">
        <list string="Wallet Recharge List" create="false" edit="false" default_order="id desc">
            <field name="id" string="ID"/>
            <field name="user_id" readonly="1"/>
            <field name="subscription_id" readonly="1"/>
            <field name="create_date" string="Created On"/>
            <field name="amount" string="Amount"/>
            <field name="start_datetime" string="Start Date"/>
            <field name="end_datetime" string="Expire Date"/>
            <field name="status" string="Status"/> 
            <field name="payment_status" string="Payment Status"/>
                </list>
            </field>
        </record>

    <!-- Action -->
    <record id="wallet_recharge_list" model="ir.actions.act_window">
        <field name="name">Past Payment History</field>
        <field name="res_model">whatsapp.payment.wizard</field>
        <field name="view_mode">list</field>
        <field name="target">current</field>
    </record>

    <!-- Menu -->
    <menuitem
        id="recharge_list"
        name="Payment History"
        parent="go4whatsapp_linker_root"
        action="wallet_recharge_list"
        sequence="1"
    />
</odoo>
