<odoo>
    <record id="view_picking_form_inherit_custom_column" model="ir.ui.view">
      <field name="name">stock.picking.form.inherit.custom.code</field>
      <field name="model">stock.picking</field>
      <field name="inherit_id" ref="stock.view_picking_form" />
      <field name="arch" type="xml">
        <!-- Insert inside the move_lines (Operations tab) -->
        <xpath expr="//field[@name='move_ids_without_package']/list/field[@name='product_id']" position="before">
          <field name="combo_product_name" readonly="1"/>
        </xpath>
      </field>
    </record>
  </odoo>