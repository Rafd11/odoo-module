<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_bom_form_inherit_whatsapp" model="ir.ui.view">
            <field name="name">mrp.bom.form.inherit.whatsapp</field>
            <field name="model">mrp.bom</field>
            <field name="inherit_id" ref="mrp.mrp_bom_form_view"/>
            <field name="arch" type="xml">
                <!-- Locate component list and add your fields -->
                <xpath expr="//field[@name='bom_line_ids']/list" position="inside">
                    <field name="free_qty"/>
                    <field name="unit_price"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
