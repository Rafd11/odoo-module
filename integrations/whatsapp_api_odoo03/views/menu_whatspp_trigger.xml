<odoo>
    <record id="view_whatsapp_trigger_form" model="ir.ui.view">
        <field name="name">whatsapp.trigger.form</field>
        <field name="model">whatsapp.trigger</field>
        <field name="arch" type="xml">
            <form string="WhatsApp Trigger">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="active"/>
                    </group>
                    <group>
                        <field name="model_id" options="{'no_create': True}"/>
                        <field name="send_type"/>
                    </group>
                    <group>
                        <field name="trigger_state" widget="selection"/>
                        <field name="trigger_automatically" />
                        <field name="Whatsapp_template" />
                    </group>

                    <separator string="Template Field Mappings"/>  
                    <field name="field_mapping_ids" nolabel="1">
                        <list editable="bottom" create="false" delete="false">
                            <field name="template_field"/>
                            <field name="model_field_id"/>
                        </list>
                    </field>
                    
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_whatsapp_trigger_list" model="ir.ui.view">
        <field name="name">whatsapp.trigger.list</field>
        <field name="model">whatsapp.trigger</field>
        <field name="arch" type="xml">
            <list>
                
                <field name="name"/>
                <field name="model_id"/>
                <field name="trigger_state"/>
                <field name="send_type"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="action_whatsapp_trigger" model="ir.actions.act_window">
        <field name="name">Set Triggers Points</field>
        <field name="res_model">whatsapp.trigger</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_whatsapp_trigger" name="Triggers"
              parent="go4whatsapp_linker_root"
              action="action_whatsapp_trigger"/>
</odoo>
