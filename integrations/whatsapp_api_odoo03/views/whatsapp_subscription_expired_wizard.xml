<odoo>
    <record id="view_whatsapp_subscription_expired_wizard" model="ir.ui.view">
        <field name="name">whatsapp.subscription.expired.wizard.form</field>
        <field name="model">whatsapp.subscription.expired.wizard</field>
        <field name="arch" type="xml">
            <form string="Subscription Expired">
                <sheet>
                    <div class="oe_title">
                        <h3 style="color:#d9534f;">
                            Your WhatsApp Connector plan has expired.
                        </h3>
                        <p style="margin-top:10px;">
                            Please subscribe now to continue using WhatsApp services.
                        </p>
                    </div>
                </sheet>

                <footer>
                    <button string="Subscribe Now"
                            type="object"
                            name="action_subscribe_now"
                            class="btn-primary"/>

                    <button string="Cancel"
                            special="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
