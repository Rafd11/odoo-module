<odoo>
    <record id="view_payment_confirm_wizard" model="ir.ui.view">
        <field name="name">payment.confirm.wizard.form</field>
        <field name="model">payment.confirm.wizard</field>
        <field name="arch" type="xml">
            <form string="Confirm Payment">
                <sheet>
                    <field name="apply_free_trial_plan" invisible="1"/>
                    <div class="oe_title"  invisible="not apply_free_trial_plan">
                        <h3>Please complete your payment to continue, or start your 7-day free trial.</h3>
                    </div>

                    <div class="oe_title"  invisible="apply_free_trial_plan">
                        <h3>Your 7-day free trial has expire Please complete your payment to continue.</h3>
                        
                    </div>
                    <br/>
                    <button string="7-day free trial"
                        type="object"
                        name="assign_free_trial_plan"
                        class="btn-primary"
                        invisible="not apply_free_trial_plan"/>
                </sheet>
                <footer>
                    <button string="Pay Now"
                            type="object"
                            name="action_open_payment"
                            class="btn-primary"/>
                    
                    <button string="I Have Paid"
                            type="object"
                            name="action_i_have_paid"
                            class="btn-success"/>

                    <button string="Cancel"
                            special="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
