<odoo>
    <!-- list View -->
    <record id="view_set_trigger_point_list" model="ir.ui.view">
        <field name="name">set.trigger.point.list</field>
        <field name="model">set.trigger.point</field>
        <field name="arch" type="xml"> 
            <list>
                <field name="name" />
                <field name="module_name_id"/>
                <field name="trigger_point_id"/>
                <field name="header_type"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_set_trigger_point_form" model="ir.ui.view">
        <field name="name">set.trigger.point.form</field>
        <field name="model">set.trigger.point</field>
        <field name="arch" type="xml"> 
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="module_name_id"/>
                        <field name="trigger_point_id"/>
                        <field name="field_selection" widget="many2many_tags"/>
                        <field name="header_type"/>
                        <field name="template_id"/>
                        <field name="model_db_name" invisible="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_set_trigger_point" model="ir.actions.act_window">
        <field name="name">Set Trigger Point</field>
        <field name="res_model">set.trigger.point</field>
        <field name="view_mode">list,form</field>
    </record>
    
</odoo>
