<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Status History Tree View -->
    <record id="view_helpdesk_ticket_status_history_tree" model="ir.ui.view">
        <field name="name">helpdesk.ticket.status.history.tree</field>
        <field name="model">helpdesk.ticket.status.history</field>
        <field name="arch" type="xml">
            <list string="Status History">
                <field name="change_date" string="Date" widget="datetime"/>
                <field name="user_id" string="Changed By"/>
                <field name="old_state" string="From" widget="badge"
                       decoration-info="old_state == 'new'"
                       decoration-warning="old_state == 'in_progress'"
                       decoration-success="old_state == 'resolved'"
                       decoration-muted="old_state == 'closed' or old_state == 'cancelled'"/>
                <field name="new_state" string="To" widget="badge"
                       decoration-info="new_state == 'new'"
                       decoration-warning="new_state == 'in_progress'"
                       decoration-success="new_state == 'resolved'"
                       decoration-muted="new_state == 'closed' or new_state == 'cancelled'"/>
                <field name="reason" string="Reason"/>
                <field name="note" string="Note"/>
            </list>
        </field>
    </record>

    <!-- Status History Form View -->
    <record id="view_helpdesk_ticket_status_history_form" model="ir.ui.view">
        <field name="name">helpdesk.ticket.status.history.form</field>
        <field name="model">helpdesk.ticket.status.history</field>
        <field name="arch" type="xml">
            <form string="Status History">
                <sheet>
                    <group>
                        <group>
                            <field name="ticket_id" readonly="1"/>
                            <field name="change_date" readonly="1"/>
                            <field name="user_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="old_state" readonly="1" widget="badge"/>
                            <field name="new_state" readonly="1" widget="badge"/>
                            <field name="reason" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="note" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action for Status History -->
    <record id="action_helpdesk_ticket_status_history" model="ir.actions.act_window">
        <field name="name">Status History</field>
        <field name="res_model">helpdesk.ticket.status.history</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('ticket_id', '=', active_id)]</field>
    </record>

</odoo>
