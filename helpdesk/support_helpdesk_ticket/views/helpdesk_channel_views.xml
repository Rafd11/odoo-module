<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ==================== Search View ==================== -->
    <record id="view_helpdesk_channel_search" model="ir.ui.view">
        <field name="name">helpdesk.channel.search</field>
        <field name="model">helpdesk.channel</field>
        <field name="arch" type="xml">
            <search string="Channels">
                <field name="name" string="Channel Name"/>
                <field name="code" string="Code"/>
                
                <!-- Filters -->
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                <filter string="Archived" name="archived" domain="[('active', '=', False)]"/>
                
                <!-- Group By -->
                <separator string="Group By"/>
                <group>
                    <filter string="Active" name="group_active" context="{'group_by': 'active'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ==================== Tree/List View ==================== -->
    <record id="view_helpdesk_channel_tree" model="ir.ui.view">
        <field name="name">helpdesk.channel.tree</field>
        <field name="model">helpdesk.channel</field>
        <field name="arch" type="xml">
            <list string="Channels" decoration-muted="active == False" default_order="sequence, name">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="icon"/>
                <field name="ticket_count" string="Tickets"/>
                <field name="open_ticket_count" string="Open Tickets"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- ==================== Form View ==================== -->
    <record id="view_helpdesk_channel_form" model="ir.ui.view">
        <field name="name">helpdesk.channel.form</field>
        <field name="model">helpdesk.channel</field>
        <field name="arch" type="xml">
            <form string="Channel">
                <header>
                    <field name="active" widget="boolean_toggle"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="%(action_helpdesk_ticket)d" type="action" 
                                class="oe_stat_button" icon="fa-ticket"
                                domain="[('channel_id', '=', id)]">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Tickets</span>
                                <span class="o_stat_value">
                                    <field name="ticket_count" widget="statinfo"/>
                                </span>
                            </div>
                        </button>
                        <button name="%(action_helpdesk_ticket)d" type="action" 
                                class="oe_stat_button" icon="fa-clock-o"
                                domain="[('channel_id', '=', id), ('state', 'not in', ['closed', 'cancelled'])]">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Open</span>
                                <span class="o_stat_value">
                                    <field name="open_ticket_count" widget="statinfo"/>
                                </span>
                            </div>
                        </button>
                    </div>
                    
                    <group>
                        <group>
                            <field name="name" placeholder="Enter channel name..."/>
                            <field name="code" placeholder="e.g., email, web, phone"/>
                            <field name="sequence"/>
                            <field name="icon" placeholder="e.g., fa-envelope, fa-globe, fa-phone"/>
                            <field name="color" widget="color_picker"/>
                        </group>
                        <group>
                            <field name="description" placeholder="Enter channel description..." nolabel="1"/>
                        </group>
                    </group>
                    
                    <notebook>
                        <page string="Default Configuration" name="defaults">
                            <group>
                                <group>
                                    <field name="default_team_id" options="{'no_create': True}"/>
                                    <field name="default_user_id" options="{'no_create': True}"/>
                                </group>
                                <group>
                                    <field name="default_priority" widget="radio" options="{'horizontal': true}"/>
                                    <field name="default_sla_policy_id" options="{'no_create': True}"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ==================== Action ==================== -->
    <record id="action_helpdesk_channel" model="ir.actions.act_window">
        <field name="name">Channels</field>
        <field name="res_model">helpdesk.channel</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_helpdesk_channel_search"/>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first channel!
            </p>
            <p>
                Channels represent the different ways customers can create tickets (Email, Web Portal, Phone, Social Media, etc.).
            </p>
        </field>
    </record>

</odoo>
