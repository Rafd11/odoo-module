<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Ticket Type Tree View -->
    <record id="view_helpdesk_ticket_type_tree" model="ir.ui.view">
        <field name="name">helpdesk.ticket.type.tree</field>
        <field name="model">helpdesk.ticket.type</field>
        <field name="arch" type="xml">
            <list string="Ticket Types" decoration-muted="active == False">
                <field name="name"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- Ticket Type Form View -->
    <record id="view_helpdesk_ticket_type_form" model="ir.ui.view">
        <field name="name">helpdesk.ticket.type.form</field>
        <field name="model">helpdesk.ticket.type</field>
        <field name="arch" type="xml">
            <form string="Ticket Type">
                <sheet>
                    <group>
                        <group>
                            <field name="name" placeholder="Enter ticket type name..."/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="description" placeholder="Enter description..."/>
                        </group>
                    </group>

                    <group string="Defaults">
                        <group>
                            <field name="default_priority"/>
                            <field name="default_category_id"/>
                        </group>
                        <group>
                            <field name="default_team_id"/>
                            <field name="default_sla_policy_id"/>
                        </group>
                    </group>

                    <group string="Templates &amp; Configuration" colspan="2">
                        <group>
                            <field name="default_template_id" options="{'no_create_edit': True}"/>
                        </group>
                        <group>
                            <field name="form_configuration" widget="text"
                                   placeholder="Optional JSON or notes about which fields to show/require for this type..."/>
                        </group>
                        <group string="Related Templates" colspan="2">
                            <field name="template_ids" nolabel="1">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="active"/>
                                </list>
                            </field>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Ticket Type Search View -->
    <record id="view_helpdesk_ticket_type_search" model="ir.ui.view">
        <field name="name">helpdesk.ticket.type.search</field>
        <field name="model">helpdesk.ticket.type</field>
        <field name="arch" type="xml">
            <search string="Ticket Types">
                <field name="name"/>
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                <filter string="Archived" name="archived" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <!-- Ticket Type Action -->
    <record id="action_helpdesk_ticket_type" model="ir.actions.act_window">
        <field name="name">Ticket Types</field>
        <field name="res_model">helpdesk.ticket.type</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_helpdesk_ticket_type_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first ticket type!
            </p>
            <p>
                Ticket types help categorize and route tickets.
            </p>
        </field>
    </record>

</odoo>
