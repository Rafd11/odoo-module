<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ==================== Ticket Volume Reports - Daily Pivot ==================== -->
    <record id="view_helpdesk_ticket_volume_daily_pivot" model="ir.ui.view">
        <field name="name">helpdesk.ticket.volume.daily.pivot</field>
        <field name="model">helpdesk.ticket</field>
        <field name="arch" type="xml">
            <pivot string="Ticket Volume (Daily)">
                <field name="team_id" type="row"/>
                <field name="ticket_type_id" type="row"/>
                <field name="priority" type="row"/>
                <field name="channel_id" type="row"/>
                <field name="create_date" interval="day" type="col"/>
<!--                <field name="id" type="measure" string="Ticket Count" operator="count"/>-->
            </pivot>
        </field>
    </record>

    <!-- ==================== Ticket Volume Reports - Weekly Pivot ==================== -->
    <record id="view_helpdesk_ticket_volume_weekly_pivot" model="ir.ui.view">
        <field name="name">helpdesk.ticket.volume.weekly.pivot</field>
        <field name="model">helpdesk.ticket</field>
        <field name="arch" type="xml">
            <pivot string="Ticket Volume (Weekly)">
                <field name="team_id" type="row"/>
                <field name="ticket_type_id" type="row"/>
                <field name="priority" type="row"/>
                <field name="channel_id" type="row"/>
                <field name="create_date" interval="week" type="col"/>
<!--                <field name="id" type="measure" string="Ticket Count" operator="count"/>-->
            </pivot>
        </field>
    </record>

    <!-- ==================== Ticket Volume Reports - Monthly Pivot ==================== -->
    <record id="view_helpdesk_ticket_volume_monthly_pivot" model="ir.ui.view">
        <field name="name">helpdesk.ticket.volume.monthly.pivot</field>
        <field name="model">helpdesk.ticket</field>
        <field name="arch" type="xml">
            <pivot string="Ticket Volume (Monthly)">
                <field name="team_id" type="row"/>
                <field name="ticket_type_id" type="row"/>
                <field name="priority" type="row"/>
                <field name="channel_id" type="row"/>
                <field name="create_date" interval="month" type="col"/>
<!--                <field name="id" type="measure" string="Ticket Count" operator="count"/>-->
            </pivot>
        </field>
    </record>

    <!-- ==================== Ticket Volume - Bar Chart (Team-wise) ==================== -->
    <record id="view_helpdesk_ticket_volume_team_bar_graph" model="ir.ui.view">
        <field name="name">helpdesk.ticket.volume.team.bar.graph</field>
        <field name="model">helpdesk.ticket</field>
        <field name="arch" type="xml">
            <graph string="Ticket Volume by Team" type="bar">
                <field name="team_id" type="row"/>
<!--                <field name="id" type="measure"/>-->
            </graph>
        </field>
    </record>

    <!-- ==================== Ticket Volume - Line Chart (Timeline) ==================== -->
    <record id="view_helpdesk_ticket_volume_timeline_line_graph" model="ir.ui.view">
        <field name="name">helpdesk.ticket.volume.timeline.line.graph</field>
        <field name="model">helpdesk.ticket</field>
        <field name="arch" type="xml">
            <graph string="Ticket Volume Over Time" type="line">
                <field name="create_date" interval="day" type="row"/>
<!--                <field name="id" type="measure"/>-->
            </graph>
        </field>
    </record>

    <!-- ==================== Ticket Volume - Pie Chart (Type-wise) ==================== -->
    <record id="view_helpdesk_ticket_volume_type_pie_graph" model="ir.ui.view">
        <field name="name">helpdesk.ticket.volume.type.pie.graph</field>
        <field name="model">helpdesk.ticket</field>
        <field name="arch" type="xml">
            <graph string="Ticket Volume by Type" type="pie">
                <field name="ticket_type_id" type="row"/>
<!--                <field name="id" type="measure"/>-->
            </graph>
        </field>
    </record>

    <!-- ==================== Ticket Volume Report Action ==================== -->
    <record id="action_helpdesk_ticket_volume_report" model="ir.actions.act_window">
        <field name="name">Ticket Volume Report</field>
        <field name="res_model">helpdesk.ticket</field>
        <field name="view_mode">list,pivot,graph</field>
        <field name="view_id" ref="view_helpdesk_ticket_volume_daily_pivot"/>
        <field name="search_view_id" ref="view_helpdesk_ticket_search"/>
        <field name="context">
            {
                'search_default_group_team': 1,
                'search_default_group_type': 1
            }
        </field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Ticket Volume Report
            </p>
            <p>
                Analyze ticket volumes over time with daily, weekly, and monthly breakdowns.
                Use the Creation Date filter to apply custom date ranges, and export results from the list or pivot view.
            </p>
        </field>
    </record>

</odoo>

