        <!-- Ticket Creators: Can read active tags -->
        <record id="helpdesk_tag_creator_rule" model="ir.rule">
            <field name="name">Helpdesk Tag: Ticket Creator Access</field>
            <field name="model_id" search="[('model', '=', 'helpdesk.tag')]" model="ir.model"/>
            <field name="domain_force">[('active', '=', True)]</field>
            <field name="groups" eval="[(4, ref('group_helpdesk_ticket_creator'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- ==================== Template Record Rules ==================== -->
        
        <!-- Portal Users: Can read active templates -->
        <record id="helpdesk_template_portal_rule" model="ir.rule">
            <field name="name">Helpdesk Template: Portal User Access</field>
            <field name="model_id" search="[('model', '=', 'helpdesk.ticket.template')]" model="ir.model"/>
            <field name="domain_force">[('active', '=', True)]</field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Ticket Creators: Can read active templates -->
        <record id="helpdesk_template_creator_rule" model="ir.rule">
            <field name="name">Helpdesk Template: Ticket Creator Access</field>
            <field name="model_id" search="[('model', '=', 'helpdesk.ticket.template')]" model="ir.model"/>
            <field name="domain_force">[('active', '=', True)]</field>
            <field name="groups" eval="[(4, ref('group_helpdesk_ticket_creator'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- ==================== Status History Record Rules ==================== -->
        
        <!-- Portal Users: Can only see status history for their own tickets -->
        <record id="helpdesk_status_history_portal_rule" model="ir.rule">
            <field name="name">Helpdesk Status History: Portal User Access</field>
            <field name="model_id" search="[('model', '=', 'helpdesk.ticket.status.history')]" model="ir.model"/>
            <field name="domain_force">[
                ('ticket_id.partner_id', '=', user.partner_id.id)
            ]</field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- ==================== Model Link Record Rules ==================== -->
        
        <!-- Portal Users: Can only see links for their own tickets -->
        <record id="helpdesk_model_link_portal_rule" model="ir.rule">
            <field name="name">Helpdesk Model Link: Portal User Access</field>
            <field name="model_id" search="[('model', '=', 'helpdesk.ticket.model.link')]" model="ir.model"/>
            <field name="domain_force">[
                ('ticket_id.partner_id', '=', user.partner_id.id)
            ]</field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- ==================== Attachment/File Access Rules ==================== -->
        
        <!-- Note: Attachment access for portal users is automatically controlled 
             through the ticket access rules. Portal users can only access attachments
             for tickets they have access to (their own tickets). -->
