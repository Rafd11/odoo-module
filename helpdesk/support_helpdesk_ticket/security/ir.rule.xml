<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- ==================== Ticket Record Rules ==================== -->
        
        <!-- Portal Users: Can only see their own tickets -->
        <record id="helpdesk_ticket_portal_rule" model="ir.rule">
            <field name="name">Helpdesk Ticket: Portal User Access</field>
            <field name="model_id" search="[('model', '=', 'helpdesk.ticket')]" model="ir.model"/>
            <field name="domain_force">[
                '|',
                ('partner_id', '=', user.partner_id.id),
                ('partner_id', 'child_of', user.commercial_partner_id.id)
            ]</field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Helpdesk Users: Can see assigned tickets and team tickets -->
        <record id="helpdesk_ticket_user_rule" model="ir.rule">
            <field name="name">Helpdesk Ticket: User Access</field>
            <field name="model_id" search="[('model', '=', 'helpdesk.ticket')]" model="ir.model"/>
            <field name="domain_force">[
                '|',
                '|',
                ('user_id', '=', user.id),
                ('team_id.member_ids', 'in', [user.id]),
                ('team_id', '=', False)
            ]</field>
            <field name="groups" eval="[(4, ref('group_helpdesk_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Helpdesk Agents: Can see team tickets -->
        <record id="helpdesk_ticket_agent_rule" model="ir.rule">
            <field name="name">Helpdesk Ticket: Agent Access</field>
            <field name="model_id" search="[('model', '=', 'helpdesk.ticket')]" model="ir.model"/>
            <field name="domain_force">[
                '|',
                ('team_id.member_ids', 'in', [user.id]),
                ('team_id', '=', False)
            ]</field>
            <field name="groups" eval="[(4, ref('group_helpdesk_agent'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Helpdesk Managers: Full access (no domain restriction) -->
        <record id="helpdesk_ticket_manager_rule" model="ir.rule">
            <field name="name">Helpdesk Ticket: Manager Access</field>
            <field name="model_id" search="[('model', '=', 'helpdesk.ticket')]" model="ir.model"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_helpdesk_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Ticket Creators: Can only see and create tickets they created, cannot update -->
        <record id="helpdesk_ticket_creator_rule" model="ir.rule">
            <field name="name">Helpdesk Ticket: Creator Access</field>
            <field name="model_id" search="[('model', '=', 'helpdesk.ticket')]" model="ir.model"/>
            <field name="domain_force">[('create_uid', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_helpdesk_ticket_creator'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- ==================== Category Record Rules ==================== -->
        
        <!-- Portal Users: Can read active categories -->
        <record id="helpdesk_category_portal_rule" model="ir.rule">
            <field name="name">Helpdesk Category: Portal User Access</field>
            <field name="model_id" search="[('model', '=', 'helpdesk.category')]" model="ir.model"/>
            <field name="domain_force">[('active', '=', True)]</field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Ticket Creators: Can read active categories -->
        <record id="helpdesk_category_creator_rule" model="ir.rule">
            <field name="name">Helpdesk Category: Ticket Creator Access</field>
            <field name="model_id" search="[('model', '=', 'helpdesk.category')]" model="ir.model"/>
            <field name="domain_force">[('active', '=', True)]</field>
            <field name="groups" eval="[(4, ref('group_helpdesk_ticket_creator'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- ==================== Tag Record Rules ==================== -->
        
        <!-- Portal Users: Can read active tags -->
        <record id="helpdesk_tag_portal_rule" model="ir.rule">
            <field name="name">Helpdesk Tag: Portal User Access</field>
            <field name="model_id" search="[('model', '=', 'helpdesk.tag')]" model="ir.model"/>
            <field name="domain_force">[('active', '=', True)]</field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
