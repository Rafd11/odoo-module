<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Auto-Close Resolved Tickets Cron Job -->
    <record id="ir_cron_auto_close_resolved_tickets" model="ir.cron">
        <field name="name">Helpdesk: Auto-Close Resolved Tickets</field>
        <field name="model_id" ref="model_helpdesk_ticket"/>
        <field name="state">code</field>
        <field name="code">model._auto_close_resolved_tickets()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active" eval="True"/>
    </record>
</odoo>
