<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Cron Job: Process Scheduled Notifications -->
        <record id="ir_cron_process_scheduled_notifications" model="ir.cron">
            <field name="name">Process Scheduled Notifications</field>
            <field name="model_id" ref="model_helpdesk_notification_schedule"/>
            <field name="state">code</field>
            <field name="code">model.process_scheduled_notifications()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="active">True</field>
            <field name="user_id" ref="base.user_root"/>
        </record>
    </data>
</odoo>
