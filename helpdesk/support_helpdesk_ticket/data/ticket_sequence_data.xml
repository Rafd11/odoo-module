<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Default Ticket Sequence -->
        <record id="sequence_helpdesk_ticket" model="ir.sequence">
            <field name="name">Helpdesk Ticket Sequence</field>
            <field name="code">helpdesk.ticket</field>
            <field name="prefix">TKT/%(year)s/</field>
            <field name="padding">4</field>
            <field name="number_increment">1</field>
            <field name="number_next">1</field>
            <field name="use_date_range">True</field>
        </record>

        <!-- Date Range for 2024 -->
        <record id="sequence_helpdesk_ticket_date_range_2024" model="ir.sequence.date_range">
            <field name="sequence_id" ref="sequence_helpdesk_ticket"/>
            <field name="date_from">2024-01-01</field>
            <field name="date_to">2024-12-31</field>
            <field name="number_next">1</field>
        </record>

        <!-- Call Log Sequence -->
        <record id="sequence_helpdesk_call_log" model="ir.sequence">
            <field name="name">Helpdesk Call Log Sequence</field>
            <field name="code">helpdesk.call.log</field>
            <field name="prefix">CALL</field>
            <field name="padding">4</field>
            <field name="number_increment">1</field>
            <field name="number_next">1</field>
        </record>
    </data>
</odoo>
