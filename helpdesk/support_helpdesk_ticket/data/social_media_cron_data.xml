<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Cron Job for Fetching Social Media Posts -->
        <record id="ir_cron_fetch_social_media_posts" model="ir.cron">
            <field name="name">Fetch Social Media Posts</field>
            <field name="model_id" ref="model_helpdesk_social_media_cron"/>
            <field name="state">code</field>
            <field name="code">model.cron_fetch_social_media_posts()</field>
            <field name="interval_number">15</field>
            <field name="interval_type">minutes</field>
            <field name="active">True</field>
        </record>
    </data>
</odoo>
