<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Cron Job: Process Due Reminders -->
        <record id="ir_cron_process_reminders" model="ir.cron">
            <field name="name">Process Due Reminders</field>
            <field name="model_id" ref="model_helpdesk_reminder"/>
            <field name="state">code</field>
            <field name="code">model.process_due_reminders()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="active">True</field>
            <field name="user_id" ref="base.user_root"/>
        </record>
        
        <!-- Cron Job: Check Reminder Rules -->
        <record id="ir_cron_check_reminder_rules" model="ir.cron">
            <field name="name">Check Reminder Rules</field>
            <field name="model_id" ref="model_helpdesk_ticket"/>
            <field name="state">code</field>
            <field name="code">model._check_reminder_rules_batch()</field>
            <field name="interval_number">4</field>
            <field name="interval_type">hours</field>
            <field name="active">True</field>
            <field name="user_id" ref="base.user_root"/>
        </record>
    </data>
</odoo>
