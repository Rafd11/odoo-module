<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="pos_custom_receipt_ssm.Orderline">
    <t t-set="line" t-value="props.line" />
    <!-- Prefer explicit index prop; fallback to line._lineIndex computed in patches.js; finally 0 -->
    <t t-set="index" t-value="typeof props.index === 'number' ? props.index : (typeof line._lineIndex === 'number' ? line._lineIndex : 0)" />
        <li class="orderline position-relative d-flex cursor-pointer" 
            t-attf-class="{{ line.comboParent ? 'orderline-combo ms-4 fst-italic' : '' }}" 
            t-att-class="props.class"
            style="padding: 4px 12px;">
            <div class="product-order"></div>
            <div t-if="line.imageSrc" class="o_line_container d-flex align-items-center justify-content-center">
                <img t-attf-style="border-radius: 1rem;" t-att-src="line.imageSrc"/>
            </div>
            <div class="d-flex flex-row w-100" style="gap: 10px;">
                <!-- No column -->
                <div class="col-no">
                    <span t-esc="index + 1"></span>
                </div>
                <!-- Item column -->
                <div class="col-item text-truncate fw-bolder">
                    <span t-esc="line.productName"></span>
                    <t t-slot="product-name"></t>
                </div>
                <!-- Qty column -->
                <div class="col-qty text-center">
                    <span t-esc="parseSignleValue(line.qty)"></span>
                </div>
                <!-- MRP column -->
                <div class="col-mrp text-end">
                    <span t-esc="parsePrice(line._mrp or 0)" />
                </div>
                <!-- Disc column -->
                <div class="col-disc text-end">
                    <t t-set="__mrp" t-value="parsePrice(line._mrp or 0)" />
                    <t t-set="__unitPrice" t-value="line.unitPrice and line.unitPrice.replace('\u20b9', '').replace(',', '') or 0" />
                    <t t-set="__diff" t-value="(parsePrice(__mrp) - parsePrice(__unitPrice))" />
                    <!-- Show discount as a single decimal (e.g., 0.2 instead of 0.200000000000) -->
                    <t t-set="__discVal" t-value="(__diff &gt; 0 ? __diff : 0) * parseSignleValue(line.qty)" />
                    <span t-esc="(Math.round(__discVal * 10) / 10).toFixed(1)" />
                </div>
                <!-- Net column -->
                <div class="col-net fw-bolder text-end">
                    <t t-set="__unitPrice" t-value="line.unitPrice and line.unitPrice.replace('\u20b9', '').replace(',', '') or 0" />
                    <t t-set="__net" t-value="parsePrice(__unitPrice) * line.qty" />
                    <!-- Show net with one decimal place -->
                    <span t-esc="(Math.round(__net * 10) / 10).toFixed(1)" />
                </div>
            </div>
            <ul class="info-list d-flex flex-row align-items-center gap-2 mb-0 ps-2" style="flex: 1;">
                <li t-if="line.price !== 0 and line.discount and line.discount !== '0'">
                    <t t-esc="line.price_without_discount" /> With a <em><t t-esc="line.discount" />% </em> discount
                </li>
                <li t-if="line.customerNote" class="customer-note px-2 ms-2 rounded text-bg-warning bg-opacity-25">
                    <i class="fa fa-sticky-note me-1" role="img" aria-label="Customer Note" title="Customer Note"></i>
                    <t t-esc="line.customerNote" />
                </li>
                <div class="internal-note-container d-flex gap-2">
                    <t t-foreach="line.internalNote?.split?.('\n') or []" t-as="note" t-key="note_index">
                        <li t-if="note.trim() !== ''" t-esc="note" class="internal-note badge px-2 rounded-pill bg-info text-info bg-opacity-25" style="font-size: 0.85rem;"></li>
                    </t>
                </div>
                <li t-foreach="line.packLotLines or []" t-as="lot" t-key="lot_index" t-esc="lot" />
                <t t-slot="default"></t>
            </ul>
        </li>
    </t>
</templates>
