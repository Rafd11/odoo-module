<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="pos_custom_receipt_ssm.OrderReceipt">
        <div class="pos-receipt">
            <t t-set="showTaxGroupLabels" t-value="doesAnyOrderlineHaveTaxLabel()"/>
            <ReceiptHeader data="props.data.headerData" />

            <div class="paymentlines text-start text-center">
                <span style="margin-left:50%;">Date: </span>
                <t t-esc="getCurrentDate()" />
            </div>
            <div class="paymentlines text-start text-center">
                <span style="margin-left: 50%;">Time: </span>
                <t t-esc="getCurrentTime()" />
            </div>

            <OrderWidget lines="props.data.orderlines" t-slot-scope="scope" generalNote="props.data.generalNote or ''" screenName="props.data.screenName">
                <t t-set="line" t-value="scope.line"/>
                <!-- Use the foreach-provided index for reliable S.No in print -->
                <Orderline basic_receipt="props.basic_receipt"
                          index="scope.line_index"
                          line="line"
                          class="{ 'px-0': true }"
                          showTaxGroupLabels="showTaxGroupLabels">
                    <li t-if="line.customerNote" class="customer-note w-100 p-2 my-1 rounded text-break">
                        <i class="fa fa-sticky-note me-1" role="img" aria-label="Customer Note" title="Customer Note"/>
                        <t t-esc="line.customerNote" />
                    </li>
                </Orderline>
            </OrderWidget>

            <t t-if="!props.basic_receipt">
                <div t-if="props.data.tax_details.length &gt; 0" class="pos-receipt-taxes">
                    <div class="text-center">--------------------------------</div>
                    <div class="d-flex">
                        <span t-if="showTaxGroupLabels" class="me-2" style="visibility: hidden;">A</span>
                        <span class="fw-bolder">Untaxed Amount</span>
                        <span t-esc="props.formatCurrency(props.data.total_without_tax)" class="ms-auto"/>
                    </div>

                    <div t-foreach="props.data.tax_details" t-as="tax" t-key="tax.id" class="d-flex">
                        <t t-if="showTaxGroupLabels">
                            <span t-if="tax.tax_group_id.pos_receipt_label" t-esc="tax.tax_group_id.pos_receipt_label" class="me-2"/>
                            <span t-else="" class="me-2" style="visibility: hidden;">A</span>
                        </t>
                        <span>
                            <span t-esc="tax.name"/>
                            on
                            <span t-esc="props.formatCurrency(tax.base)"/>
                        </span>
                        <span t-esc="props.formatCurrency(tax.amount)" class="ms-auto"/>
                    </div>
                </div>

                <div class="text-center">-------------------------------------</div>
                
                <!-- Sub Total = Sum of (MRP * Qty) for all items -->
                <div class="paymentlines text-start text-center">
                    <span style="margin-left:40%;">Sub Total: </span>
                    <span t-esc="props.formatCurrency(computeMRPSubtotal(props.data.orderlines))" class="pos-receipt-left-align"/>
                </div>

                <div class="text-center">----------------------------------</div>   
                
                <!-- Discount = Sum of all (MRP - Unit Price) * Qty -->
                <div class="text-center" style="font-weight:700; font-size:14px;">
                    <span style="margin-left:40%;">Discount: </span>
                    <span t-esc="props.formatCurrency(computeDiscountFromMRP(props.data.orderlines))" class="pos-receipt-left-align"/>
                </div>

                <!-- Total = Amount Total (actual total paid) -->
                <div class="pos-receipt-amount text-center">
                    <div class="text-center">------------------------------------------</div>
                    <span style="margin-left:40%; font-weight:700; font-size:16px;">Total: </span>
                    <span t-esc="props.formatCurrency(props.data.amount_total)" class="pos-receipt-left-align" style="font-weight:700; font-size:16px;"/>
                </div>

                <div class="pos-receipt-amount" style="font-size:12px;">
                    <span style="margin-left:10%;">Total Item: </span>
                    <span t-esc="props.data.orderlines.length" class="pos-receipt-left-align"/>
                </div>

                <t t-if="props.data.rounding_applied">
                    <div class="pos-receipt-amount" style="margin-left:10%;">
                        Rounding
                        <span t-esc='props.formatCurrency(props.data.rounding_applied)' class="pos-receipt-right-align" style="margin-right:10%;"/>
                    </div>
                    <div class="pos-receipt-amount" style="margin-left:10%;">
                        To Pay
                        <span t-esc='props.formatCurrency(props.data.amount_total + props.data.rounding_applied)' class="pos-receipt-right-align" style="margin-right:10%;"/>
                    </div>
                </t>

                <div class="paymentlines" style="margin-left:50%;" t-foreach="props.data.paymentlines" t-as="line" t-key="line_index">
                    <t class="pos-receipt-left-align" t-esc="line.name" />
                    <span t-esc="props.formatCurrency(line.amount)" />
                </div>

                <div t-if="props.data.change != 0" class="pos-receipt-amount receipt-change" style="margin-left:50%; font-size:12px">
                    CHANGE
                    <span t-esc="props.formatCurrency(props.data.change)" class="pos-receipt-left-center"/>
                </div>

                <!-- Loyalty points summary -->
                <t t-foreach="props.data.loyaltyStats or []" t-as="_loyaltyStat" t-key="_loyaltyStat.couponId">
                    <div t-if="_loyaltyStat.program.portal_visible and (_loyaltyStat.points.won || _loyaltyStat.points.spent)" class="loyalty">
                        <t t-if="_loyaltyStat.points.won">
                            <div>
                                <span><t t-esc="_loyaltyStat.points.name"/> Won: </span><t t-esc="_loyaltyStat.points.won"/>
                            </div>
                        </t>
                        <t t-if="_loyaltyStat.points.spent">
                            <div>
                                <span><t t-esc="_loyaltyStat.points.name"/> Spent: </span><t t-esc="_loyaltyStat.points.spent"/>
                            </div>
                        </t>
                        <t t-if="_loyaltyStat.points.balance">
                            <div>
                                <span>Balance <t t-esc="_loyaltyStat.points.name"/>: </span><t t-esc="_loyaltyStat.points.balance"/>
                            </div>
                        </t>
                    </div>
                </t>

                <t t-if="props.data.partner">
                    <br/>
                    <div>Customer: <t t-esc="props.data.partner.name"/></div>
                </t>

                <div class="before-footer" />

                <div t-if="props.data.pos_qr_code">
                    <br/>
                    <div class="pos-receipt-order-data mb-2">
                        Need an invoice for your purchase ?
                    </div>
                </div>

                <div t-if="['qr_code', 'qr_code_and_url'].includes(props.data.headerData.company.point_of_sale_ticket_portal_url_display_mode) and props.data.pos_qr_code" class="mb-2">
                    <img id="posqrcode" t-att-src="props.data.pos_qr_code" class="pos-receipt-logo"/>
                </div>

                <div t-if="props.data.pos_qr_code">
                    <div class="pos-receipt-order-data">
                        Unique Code: <t t-esc="props.data.ticket_code"/>
                    </div>
                </div>

                <div t-if="['url', 'qr_code_and_url'].includes(props.data.headerData.company.point_of_sale_ticket_portal_url_display_mode) and props.data.pos_qr_code">
                    <div class="pos-receipt-order-data" t-attf-class="{{ props.data.ticket_portal_url_display_mode === 'qr_code_and_url' ? 'mt-3' : '' }}">
                        Portal URL: <t t-out="props.data.base_url"/>/pos/ticket
                    </div>
                </div>
            </t>

            <div t-if="props.data.footer" class="pos-receipt-center-align" style="white-space:pre-line">
                <br/>
                <t t-esc="props.data.footer" />
                <br/>
                <br/>
            </div>

            <div class="after-footer">
                <t t-foreach="props.data.paymentlines" t-as="line" t-key="line_index">
                    <t t-if="line.ticket">
                        <br />
                        <div class="pos-payment-terminal-receipt">
                            <pre t-esc="line.ticket" />
                        </div>
                    </t>
                </t>
            </div>

            <t t-if="props.data.shippingDate">
                <div class="pos-receipt-order-data">
                    Expected delivery:
                    <div><t t-esc="props.data.shippingDate" /></div>
                </div>
            </t>
            <div class="pos-receipt-order-data">
                <!-- <p>Developed By ProcessDrive</p>
                <p>9944180573</p> -->
                <div t-esc="props.data.name" />
                <div id="order-date" t-esc="props.data.date" />
            </div>
        </div>
    </t>
</templates>
