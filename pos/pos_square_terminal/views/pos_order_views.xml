<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Add Refund on Square button on pos.order form (for old orders / back office). -->
    <record id="view_pos_order_form_square" model="ir.ui.view">
        <field name="name">pos.order.form.square</field>
        <field name="model">pos.order</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_order_form"/>
        <field name="arch" type="xml">
            <!-- Add at end of form (works whether form has sheet, header, or other layout) -->
            <xpath expr="//form" position="inside">
                <group invisible="not has_square_payment" string="Square Terminal">
                    <button name="action_refund_square" type="object" string="Refund on Square"
                            class="btn-warning" icon="fa-undo"
                            title="Refund this order's Square payment (opens wizard in same window)"/>
                </group>
            </xpath>
        </field>
    </record>

    <!-- Server action: Refund on Square from Action menu (works even if form view differs per version). -->
    <record id="action_pos_order_refund_square" model="ir.actions.server">
        <field name="name">Refund on Square</field>
        <field name="model_id" ref="point_of_sale.model_pos_order"/>
        <field name="binding_model_id" ref="point_of_sale.model_pos_order"/>
        <field name="binding_view_types">form</field>
        <field name="state">code</field>
        <field name="code">action = records.ensure_one().action_refund_square()</field>
    </record>
</odoo>
