<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="payment_provider_form_square" model="ir.ui.view">
        <field name="name">payment.provider.form.square</field>
        <field name="model">payment.provider</field>
        <field name="inherit_id" ref="payment.payment_provider_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="Square" invisible="code != 'square'">
                    <field name="square_application_id" placeholder="Application ID from Square Developer Dashboard"/>
                    <field name="square_access_token" password="True" placeholder="Sandbox or production access token"/>
                    <field name="square_location_id" optional="show" placeholder="Optional location ID"/>
                    <div class="mt-2" invisible="code != 'square'">
                        <button type="object" name="action_square_test_connection"
                                string="Test connection" class="btn btn-secondary"
                                title="Verify access token with Square API"/>
                    </div>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
