<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List view -->
    <record id="view_foupzi_github_module_list" model="ir.ui.view">
        <field name="name">foupzi.github.module.list</field>
        <field name="model">foupzi.github.module</field>
        <field name="arch" type="xml">
            <list string="GitHub Modules" decoration-success="state == 'installed'"
                  decoration-info="state == 'deployed'" default_order="category,name">
                <field name="name"/>
                <field name="category"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'installed'"
                       decoration-info="state == 'deployed'"
                       decoration-muted="state == 'available'"/>
                <field name="is_odoo_installed" invisible="1"/>
                <button name="action_deploy" string="Deploy" type="object"
                        class="btn-secondary btn-sm"
                        invisible="state != 'available'"/>
                <button name="action_deploy_and_install" string="Deploy &amp; Install" type="object"
                        class="btn-primary btn-sm"
                        invisible="state == 'installed'"/>
                <button name="action_upgrade" string="Upgrade" type="object"
                        class="btn-warning btn-sm"
                        invisible="state != 'installed'"/>
            </list>
        </field>
    </record>

    <!-- Form view -->
    <record id="view_foupzi_github_module_form" model="ir.ui.view">
        <field name="name">foupzi.github.module.form</field>
        <field name="model">foupzi.github.module</field>
        <field name="arch" type="xml">
            <form string="GitHub Module">
                <header>
                    <button name="action_deploy" string="Deploy" type="object"
                            class="btn-secondary" invisible="state != 'available'"/>
                    <button name="action_deploy_and_install" string="Deploy &amp; Install"
                            type="object" class="btn-primary"
                            invisible="state == 'installed'"/>
                    <button name="action_upgrade" string="Pull &amp; Upgrade"
                            type="object" class="btn-warning"
                            invisible="state != 'installed'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="available,deployed,installed"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="category"/>
                            <field name="github_path"/>
                        </group>
                        <group>
                            <field name="state"/>
                            <field name="odoo_module_id"/>
                            <field name="is_odoo_installed"/>
                        </group>
                    </group>
                    <group string="Last Deploy Log" invisible="not deploy_log">
                        <field name="deploy_log" nolabel="1" widget="text"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search view -->
    <record id="view_foupzi_github_module_search" model="ir.ui.view">
        <field name="name">foupzi.github.module.search</field>
        <field name="model">foupzi.github.module</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" string="Module"/>
                <field name="category"/>
                <separator/>
                <filter string="Available" name="available" domain="[('state','=','available')]"/>
                <filter string="Deployed" name="deployed" domain="[('state','=','deployed')]"/>
                <filter string="Installed" name="installed" domain="[('state','=','installed')]"/>
                <group expand="1" string="Group By">
                    <filter string="Category" name="group_category" context="{'group_by': 'category'}"/>
                    <filter string="State" name="group_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_foupzi_github_module" model="ir.actions.act_window">
        <field name="name">GitHub Modules</field>
        <field name="res_model">foupzi.github.module</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_foupzi_github_module_search"/>
        <field name="context">{'search_default_group_category': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No modules synced yet.
            </p>
            <p>Click <b>Sync from GitHub</b> to fetch your modules.</p>
        </field>
    </record>

    <!-- Shell wizard view -->
    <record id="view_foupzi_shell_wizard_form" model="ir.ui.view">
        <field name="name">foupzi.shell.wizard.form</field>
        <field name="model">foupzi.shell.wizard</field>
        <field name="arch" type="xml">
            <form string="Run Server Command">
                <group>
                    <field name="command" placeholder="e.g. git pull, odoo-bin -u my_module"/>
                    <field name="working_dir"/>
                </group>
                <footer>
                    <button name="action_run" string="Run" type="object" class="btn-primary"/>
                    <button string="Close" class="btn-secondary" special="cancel"/>
                </footer>
                <group string="Output" invisible="not output">
                    <field name="output" nolabel="1" widget="text"
                           style="font-family: monospace; background: #1e1e1e; color: #d4d4d4; padding: 12px;"/>
                </group>
            </form>
        </field>
    </record>

    <record id="action_foupzi_shell_wizard" model="ir.actions.act_window">
        <field name="name">Run Server Command</field>
        <field name="res_model">foupzi.shell.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
