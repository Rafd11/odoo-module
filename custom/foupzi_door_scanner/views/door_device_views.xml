<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!-- ── List ─────────────────────────────────────────────────────────────── -->
  <record id="view_door_device_list" model="ir.ui.view">
    <field name="name">door.device.list</field>
    <field name="model">door.device</field>
    <field name="arch" type="xml">
      <list string="Devices">
        <field name="name"/>
        <field name="state" widget="badge"
               decoration-success="state == 'paired'"
               decoration-warning="state == 'unpaired'"
               decoration-danger="state == 'revoked'"/>
        <field name="operator_id"/>
        <field name="scan_count"/>
        <field name="last_seen"/>
      </list>
    </field>
  </record>

  <!-- ── Form ─────────────────────────────────────────────────────────────── -->
  <record id="view_door_device_form" model="ir.ui.view">
    <field name="name">door.device.form</field>
    <field name="model">door.device</field>
    <field name="arch" type="xml">
      <form string="Door Device">
        <header>
          <button name="action_generate_token" string="Regenerate QR" type="object"
                  class="btn-primary" invisible="state == 'revoked'"/>
          <button name="action_revoke" string="Revoke device" type="object"
                  class="btn-danger" confirm="This will disconnect the device immediately."
                  invisible="state == 'revoked'"/>
          <field name="state" widget="statusbar" statusbar_visible="unpaired,paired,revoked"/>
        </header>
        <sheet>
          <div class="oe_title">
            <h1><field name="name" placeholder="e.g. Door 01"/></h1>
          </div>
          <group>
            <group>
              <field name="operator_id"/>
              <field name="last_seen" readonly="1"/>
              <field name="scan_count" readonly="1"/>
            </group>
            <group>
              <field name="odoo_url" readonly="1" string="Server URL"/>
            </group>
          </group>

          <notebook>
            <page string="Pairing QR" name="qr">
              <div class="text-center py-4" invisible="state != 'unpaired' and state != 'paired'">
                <p class="text-muted mb-4">
                  Open the Door Scanner app on the Android phone,
                  tap <strong>Scan pairing QR</strong>, and point the camera here.
                </p>
                <field name="pairing_qr" widget="image" options="{'size': [300, 300]}"/>
                <div class="mt-4">
                  <p class="text-muted mb-1">Or use <strong>Enter manually</strong> in the app — copy the token below:</p>
                  <field name="token" readonly="1" widget="CopyClipboardChar"/>
                </div>
              </div>
              <div invisible="state == 'unpaired' or state == 'paired'">
                <p class="text-danger">Device revoked. Regenerate the QR to re-pair.</p>
              </div>
            </page>
            <page string="Assigned events" name="events">
              <field name="event_ids" widget="many2many_tags"/>
              <p class="text-muted mt-2">
                Leave empty to allow scanning for <em>all</em> upcoming events.
              </p>
            </page>
            <page string="Scan history" name="logs">
              <field name="scan_log_ids" readonly="1">
                <list>
                  <field name="scan_time"/>
                  <field name="attendee_name"/>
                  <field name="ticket_type"/>
                  <field name="ticket_code"/>
                  <field name="result" widget="badge"
                         decoration-success="result == 'valid'"
                         decoration-warning="result == 'duplicate'"
                         decoration-danger="result in ['invalid','wrong_event','cancelled']"/>
                  <field name="event_id"/>
                </list>
              </field>
            </page>
          </notebook>
        </sheet>
        <chatter/>
      </form>
    </field>
  </record>

  <!-- ── Action ────────────────────────────────────────────────────────────── -->
  <record id="action_door_device" model="ir.actions.act_window">
    <field name="name">Devices</field>
    <field name="res_model">door.device</field>
    <field name="view_mode">list,form</field>
  </record>

</odoo>
