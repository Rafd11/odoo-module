<?xml version="1.0" encoding="utf-8"?>
<odoo>

	<data noupdate="1">
        <record id="base.user_demo" model="res.users">
            <field name="group_ids" eval="[(4, ref('bi_hr_payroll.group_hr_payroll_manager'))]"/>
        </record>
    </data>

	<record id="hr_salary_rule_sales_commission" model="hr.salary.rule">
		<field name="amount_select">code</field>
		<field name="code">SALE</field>
		<field name="category_id" ref="bi_hr_payroll.ALW"/>
		<field name="name">Get 1% of sales</field>
		<field name="sequence" eval="17"/>
		<field name="amount_python_compute">result = ((inputs.SALEURO and inputs.SALEURO.amount) + (inputs.SALASIA and inputs.SALASIA.amount)) * 0.01</field>
	 </record>

	<!-- Rule Inputs -->
	<record id="hr_rule_input_sale_a" model="hr.rule.input">
		<field name="code">SALEURO</field>
		<field name="name">Sales to Europe</field>
		<field name="input_id" ref="hr_salary_rule_sales_commission"/>
	</record>

	<record id="hr_rule_input_sale_b" model="hr.rule.input">
		<field name="code">SALASIA</field>
		<field name="name">Sales to Asia</field>
		<field name="input_id" ref="hr_salary_rule_sales_commission"/>
	</record>

	<!-- Employee -->
  	<record id="hr_employee_payroll" model="hr.employee">
	  	<field name="name">Roger Scott</field>
	  	<field name="job_title">Consultant</field>
	  	<field name="work_phone">3282823500</field>
	  	<field name="work_email">rogerscott@example.com</field>
  	</record>

	<!-- Employee Contracts (hr.version) -->
	<record id="hr_contract_firstcontract1" model="hr.version">
		<field name="name">Marketing Executive Contract</field>
		<field name="contract_date_start" eval="(DateTime.today() + relativedelta(day=1))"/>
		<field name="contract_date_end" eval="(DateTime.today() + relativedelta(month=12, day=31))"/>
		<field name="structure_type_id" ref="bi_hr_payroll.structure_001"/>
		<field name="employee_id" ref="bi_hr_payroll.hr_employee_payroll"/>
		<field name="resource_calendar_id" ref="resource.resource_calendar_std"/>
		<field name="wage" eval="4000.0"/>
		<field name="date_version" eval="(DateTime.today() + relativedelta(day=1))"/>
	</record>

	<!-- Update existing Marc Demo employee to include payroll data -->
	<record id="hr.employee_qdp" model="hr.employee">
		<field name="contract_date_start" eval="(DateTime.today() + relativedelta(day=1))"/>
		<field name="contract_date_end" eval="(DateTime.today() + relativedelta(month=12, day=31))"/>
		<field name="structure_type_id" ref="bi_hr_payroll.structure_002"/>
		<field name="wage" eval="5000.0"/>
	</record>

</odoo>